# Environment Variables
# Copy this file to .env.local and fill in your values

# Instagram Graph API Configuration
# Get your access token from: https://developers.facebook.com/docs/instagram-basic-display-api/getting-started
INSTAGRAM_ACCESS_TOKEN=your_long_lived_access_token_here
NEXT_PUBLIC_INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id_here
