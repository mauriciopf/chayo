# ─── Instagram ──────────────────────────────────────────────
INSTAGRAM_ACCESS_TOKEN=your_long_lived_access_token_here
NEXT_PUBLIC_INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id_here

# ─── Supabase ────────────────────────────────────────────────
# Get these from: https://app.supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Stripe ──────────────────────────────────────────────────
# Get these from: https://dashboard.stripe.com → Developers
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price ID for the Basic plan ($499/month) — create at stripe.com/products
STRIPE_BASIC_PRICE_ID=price_...

# ─── App ─────────────────────────────────────────────────────
# Your deployed URL (used for Stripe redirect URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
